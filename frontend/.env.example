# Base URL of the FastAPI backend. No runtime default: if this is unset, the
# site never fires a request and simply serves the bundled saved result (the
# live-run button hides). Uncomment for local dev; in production point it at
# your deployed API (see DEPLOY.md).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Must match the backend's API_SECRET exactly (see root .env.example). Sent as
# the x-api-secret header on every POST /api/analyze?fresh=true call. If this
# doesn't match, every fresh run fails with 403 (surfaced as a distinct "auth"
# error after a click, never on page load). Only needed if the backend has
# ANTHROPIC_API_KEY set, i.e. fresh runs are enabled at all.
# NEXT_PUBLIC_API_SECRET=
