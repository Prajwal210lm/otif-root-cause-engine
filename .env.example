# Backend (FastAPI) environment. Copy to .env or export in your shell.

# Anthropic API key. Enables live fresh runs; everything else (tests, cached
# canonical result, the whole frontend) works without it.
#
# FAIL-CLOSED: if this is set but API_SECRET is not, the server disables
# POST /api/analyze?fresh=true entirely (503) and logs a warning at startup.
# The two must be set together.
ANTHROPIC_API_KEY=

# Shared secret required in the x-api-secret header for POST /api/analyze?fresh=true.
# Required whenever ANTHROPIC_API_KEY is set; see the fail-closed note above.
API_SECRET=

# Allowed CORS origin(s) for the frontend, comma-separated. Required in any
# public deployment: without it, only http://localhost:3000 is allowed, and
# the server logs a startup warning.
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# Max fresh (live, paid) runs allowed per day, across all callers. Resets at
# UTC midnight. A per-IP limit of 2 runs/hour applies in addition to this.
DAILY_RUN_CAP=20

# Optional: override the canonical cache file served by GET /api/canonical.
OTIF_CANONICAL=data/canonical_run.json
